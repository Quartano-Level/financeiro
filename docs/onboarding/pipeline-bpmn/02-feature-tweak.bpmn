<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_feature_tweak" targetNamespace="http://columbia/pipeline">
  <bpmn:collaboration id="Collab_feature_tweak">
    <bpmn:participant id="Pool" name="Pipeline /feature-tweak" processRef="Proc_feature_tweak" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_feature_tweak" isExecutable="false">
    <bpmn:laneSet id="laneSet">
      <bpmn:lane id="Lane_Dev" name="Dev / Yuri (Humano)">
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>wt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gFix</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>rebase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gConflict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>callYuri</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>bump</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>pr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>endev</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Nav" name="CodebaseNavigator">
        <bpmn:flowNodeRef>nav</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Office" name="OfficeHoursInterviewer">
        <bpmn:flowNodeRef>investigate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>interview</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>fork</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Onto" name="OntologyCurator">
        <bpmn:flowNodeRef>ontoRule</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ontoIntegr</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Task" name="TaskScoper">
        <bpmn:flowNodeRef>taskscoper</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Auto" name="AutoLoopRunner">
        <bpmn:flowNodeRef>autoloop</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gGreen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p0loop</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Regis" name="Regis-Review (8x qa-*)">
        <bpmn:flowNodeRef>regis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>triage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gP0</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="start" name="/feature-tweak &lt;entity&gt; '&lt;intent&gt;'" />
    <bpmn:task id="wt" name="Step 0 — git worktree dedicado" />
    <bpmn:exclusiveGateway id="gFix" name="intent começa com 'fix:'?" />
    <bpmn:task id="rebase" name="Rebase da base + resolver conflitos" />
    <bpmn:exclusiveGateway id="gConflict" name="conflito não-trivial?" />
    <bpmn:endEvent id="callYuri" name="PARAR — chamar o Yuri" />
    <bpmn:task id="bump" name="Bump versão FE+BE (fix→patch) + commit chore(release)" />
    <bpmn:task id="pr" name="Abrir PR (gh pr create)" />
    <bpmn:endEvent id="endev" name="PR aberto" />

    <bpmn:task id="nav" name="Localiza entidade/regra + arquivos via _index.json" />

    <bpmn:task id="investigate" name="/investigate (causa-raiz) — ver caminho 4" />
    <bpmn:userTask id="interview" name="Entrevista cirúrgica (delta): atual vs desejado, invariante, teste" />
    <bpmn:exclusiveGateway id="fork" name="Tipo de mudança?" />

    <bpmn:task id="ontoRule" name="Diff da regra/propriedade (Dev aprova)" />
    <bpmn:task id="ontoIntegr" name="Atualizar integrations/*.md (OBRIGATÓRIO)" />

    <bpmn:task id="taskscoper" name="Gera tasks mínimas (1-3)" />

    <bpmn:task id="autoloop" name="TDD → impl → typecheck → lint → test → PatternGuardian" />
    <bpmn:exclusiveGateway id="gGreen" name="verde?" />
    <bpmn:task id="p0loop" name="Sub-loop P0 (NÃO dispara novo Regis-Review)" />

    <bpmn:task id="regis" name="/regis-review → KANBAN.md" />
    <bpmn:task id="triage" name="Triar P0 / P1·P2·P3 (P1-3 → inbox)" />
    <bpmn:exclusiveGateway id="gP0" name="P0 crítico?" />

    <bpmn:sequenceFlow id="f1" sourceRef="start" targetRef="wt" />
    <bpmn:sequenceFlow id="f2" sourceRef="wt" targetRef="nav" />
    <bpmn:sequenceFlow id="f3" sourceRef="nav" targetRef="gFix" />
    <bpmn:sequenceFlow id="f4" name="sim" sourceRef="gFix" targetRef="investigate" />
    <bpmn:sequenceFlow id="f5" sourceRef="investigate" targetRef="interview" />
    <bpmn:sequenceFlow id="f6" name="não" sourceRef="gFix" targetRef="interview" />
    <bpmn:sequenceFlow id="f7" sourceRef="interview" targetRef="fork" />
    <bpmn:sequenceFlow id="f8" name="mudança de regra" sourceRef="fork" targetRef="ontoRule" />
    <bpmn:sequenceFlow id="f9" name="schema de integração" sourceRef="fork" targetRef="ontoIntegr" />
    <bpmn:sequenceFlow id="f10" name="bug de implementação" sourceRef="fork" targetRef="taskscoper" />
    <bpmn:sequenceFlow id="f11" sourceRef="ontoRule" targetRef="taskscoper" />
    <bpmn:sequenceFlow id="f12" sourceRef="ontoIntegr" targetRef="taskscoper" />
    <bpmn:sequenceFlow id="f13" sourceRef="taskscoper" targetRef="autoloop" />
    <bpmn:sequenceFlow id="f14" sourceRef="autoloop" targetRef="gGreen" />
    <bpmn:sequenceFlow id="f15" name="não (reitera)" sourceRef="gGreen" targetRef="autoloop" />
    <bpmn:sequenceFlow id="f16" name="sim" sourceRef="gGreen" targetRef="regis" />
    <bpmn:sequenceFlow id="f17" sourceRef="regis" targetRef="triage" />
    <bpmn:sequenceFlow id="f18" sourceRef="triage" targetRef="gP0" />
    <bpmn:sequenceFlow id="f19" name="sim" sourceRef="gP0" targetRef="p0loop" />
    <bpmn:sequenceFlow id="f20" name="re-check" sourceRef="p0loop" targetRef="gP0" />
    <bpmn:sequenceFlow id="f21" name="não" sourceRef="gP0" targetRef="rebase" />
    <bpmn:sequenceFlow id="f22" sourceRef="rebase" targetRef="gConflict" />
    <bpmn:sequenceFlow id="f23" name="sim" sourceRef="gConflict" targetRef="callYuri" />
    <bpmn:sequenceFlow id="f24" name="não" sourceRef="gConflict" targetRef="bump" />
    <bpmn:sequenceFlow id="f25" sourceRef="bump" targetRef="pr" />
    <bpmn:sequenceFlow id="f26" sourceRef="pr" targetRef="endev" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="di">
    <bpmndi:BPMNPlane id="plane" bpmnElement="Collab_feature_tweak">
      <bpmndi:BPMNShape id="Pool_di" bpmnElement="Pool" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="3920" height="980" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Dev_di" bpmnElement="Lane_Dev" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="3890" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Nav_di" bpmnElement="Lane_Nav" isHorizontal="true">
        <dc:Bounds x="190" y="220" width="3890" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Office_di" bpmnElement="Lane_Office" isHorizontal="true">
        <dc:Bounds x="190" y="360" width="3890" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Onto_di" bpmnElement="Lane_Onto" isHorizontal="true">
        <dc:Bounds x="190" y="500" width="3890" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Task_di" bpmnElement="Lane_Task" isHorizontal="true">
        <dc:Bounds x="190" y="640" width="3890" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Auto_di" bpmnElement="Lane_Auto" isHorizontal="true">
        <dc:Bounds x="190" y="780" width="3890" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Regis_di" bpmnElement="Lane_Regis" isHorizontal="true">
        <dc:Bounds x="190" y="920" width="3890" height="140" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="start_di" bpmnElement="start"><dc:Bounds x="277" y="132" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="wt_di" bpmnElement="wt"><dc:Bounds x="410" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="nav_di" bpmnElement="nav"><dc:Bounds x="590" y="255" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gFix_di" bpmnElement="gFix" isMarkerVisible="true"><dc:Bounds x="815" y="130" width="40" height="40" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="investigate_di" bpmnElement="investigate"><dc:Bounds x="950" y="395" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="interview_di" bpmnElement="interview"><dc:Bounds x="1130" y="395" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="fork_di" bpmnElement="fork" isMarkerVisible="true"><dc:Bounds x="1355" y="410" width="40" height="40" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ontoRule_di" bpmnElement="ontoRule"><dc:Bounds x="1490" y="535" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ontoIntegr_di" bpmnElement="ontoIntegr"><dc:Bounds x="1670" y="535" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="taskscoper_di" bpmnElement="taskscoper"><dc:Bounds x="1850" y="675" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="autoloop_di" bpmnElement="autoloop"><dc:Bounds x="2030" y="815" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gGreen_di" bpmnElement="gGreen" isMarkerVisible="true"><dc:Bounds x="2255" y="830" width="40" height="40" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="regis_di" bpmnElement="regis"><dc:Bounds x="2390" y="955" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="triage_di" bpmnElement="triage"><dc:Bounds x="2570" y="955" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gP0_di" bpmnElement="gP0" isMarkerVisible="true"><dc:Bounds x="2795" y="970" width="40" height="40" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="p0loop_di" bpmnElement="p0loop"><dc:Bounds x="2930" y="815" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="rebase_di" bpmnElement="rebase"><dc:Bounds x="3110" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gConflict_di" bpmnElement="gConflict" isMarkerVisible="true"><dc:Bounds x="3335" y="130" width="40" height="40" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="callYuri_di" bpmnElement="callYuri"><dc:Bounds x="3337" y="180" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="bump_di" bpmnElement="bump"><dc:Bounds x="3470" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="pr_di" bpmnElement="pr"><dc:Bounds x="3650" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endev_di" bpmnElement="endev"><dc:Bounds x="3877" y="132" width="36" height="36" /></bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1"><di:waypoint x="313" y="150" /><di:waypoint x="410" y="150" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2"><di:waypoint x="540" y="150" /><di:waypoint x="655" y="150" /><di:waypoint x="655" y="255" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3"><di:waypoint x="720" y="290" /><di:waypoint x="835" y="290" /><di:waypoint x="835" y="170" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4"><di:waypoint x="835" y="170" /><di:waypoint x="835" y="430" /><di:waypoint x="950" y="430" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5"><di:waypoint x="1080" y="430" /><di:waypoint x="1130" y="430" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6"><di:waypoint x="855" y="150" /><di:waypoint x="1195" y="150" /><di:waypoint x="1195" y="395" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7"><di:waypoint x="1260" y="430" /><di:waypoint x="1355" y="430" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8"><di:waypoint x="1370" y="450" /><di:waypoint x="1370" y="570" /><di:waypoint x="1490" y="570" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9"><di:waypoint x="1395" y="430" /><di:waypoint x="1735" y="430" /><di:waypoint x="1735" y="535" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10"><di:waypoint x="1380" y="450" /><di:waypoint x="1380" y="710" /><di:waypoint x="1850" y="710" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11"><di:waypoint x="1555" y="605" /><di:waypoint x="1555" y="710" /><di:waypoint x="1850" y="710" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f12_di" bpmnElement="f12"><di:waypoint x="1735" y="605" /><di:waypoint x="1735" y="710" /><di:waypoint x="1850" y="710" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f13_di" bpmnElement="f13"><di:waypoint x="1980" y="710" /><di:waypoint x="2095" y="710" /><di:waypoint x="2095" y="815" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f14_di" bpmnElement="f14"><di:waypoint x="2160" y="850" /><di:waypoint x="2255" y="850" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f15_di" bpmnElement="f15"><di:waypoint x="2275" y="870" /><di:waypoint x="2275" y="900" /><di:waypoint x="2095" y="900" /><di:waypoint x="2095" y="885" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f16_di" bpmnElement="f16"><di:waypoint x="2280" y="870" /><di:waypoint x="2280" y="990" /><di:waypoint x="2390" y="990" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f17_di" bpmnElement="f17"><di:waypoint x="2520" y="990" /><di:waypoint x="2570" y="990" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f18_di" bpmnElement="f18"><di:waypoint x="2700" y="990" /><di:waypoint x="2795" y="990" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f19_di" bpmnElement="f19"><di:waypoint x="2815" y="970" /><di:waypoint x="2815" y="850" /><di:waypoint x="2930" y="850" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f20_di" bpmnElement="f20"><di:waypoint x="2995" y="885" /><di:waypoint x="2995" y="990" /><di:waypoint x="2835" y="990" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f21_di" bpmnElement="f21"><di:waypoint x="2815" y="1010" /><di:waypoint x="2815" y="1030" /><di:waypoint x="3175" y="1030" /><di:waypoint x="3175" y="185" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f22_di" bpmnElement="f22"><di:waypoint x="3240" y="150" /><di:waypoint x="3335" y="150" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f23_di" bpmnElement="f23"><di:waypoint x="3355" y="170" /><di:waypoint x="3355" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f24_di" bpmnElement="f24"><di:waypoint x="3375" y="150" /><di:waypoint x="3470" y="150" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f25_di" bpmnElement="f25"><di:waypoint x="3600" y="150" /><di:waypoint x="3650" y="150" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f26_di" bpmnElement="f26"><di:waypoint x="3780" y="150" /><di:waypoint x="3877" y="150" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
