<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Defs_feature_new" targetNamespace="http://columbia/pipeline">
  <bpmn:collaboration id="Collab_feature_new">
    <bpmn:participant id="Pool" name="Pipeline /feature-new" processRef="Proc_feature_new" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_feature_new" isExecutable="false">
    <bpmn:laneSet id="laneSet">
      <bpmn:lane id="Lane_Dev" name="Dev / Yuri (Humano)">
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>wt</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>reviewFlag</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gEntity</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>confirmTasks</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gapPause</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>rebase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gConflict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>callYuri</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>bump</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>pr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>endev</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Office" name="OfficeHoursInterviewer">
        <bpmn:flowNodeRef>interview</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Onto" name="OntologyCurator">
        <bpmn:flowNodeRef>ontology</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Task" name="TaskScoper">
        <bpmn:flowNodeRef>taskscoper</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Auto" name="AutoLoopRunner">
        <bpmn:flowNodeRef>autoloop</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>infogap</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gGreen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>p0loop</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Regis" name="Regis-Review (8x qa-*)">
        <bpmn:flowNodeRef>regis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>triage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gP0</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="start" name="/feature-new &lt;intent&gt;" />
    <bpmn:task id="wt" name="Step 0 — git worktree dedicado (C:/tmp/&lt;slug&gt;-wt)" />
    <bpmn:userTask id="reviewFlag" name="Revisar transcript — confirmar entity_changed" />
    <bpmn:exclusiveGateway id="gEntity" name="entity_changed?" />
    <bpmn:userTask id="confirmTasks" name="Confirmar tasks.md" />
    <bpmn:userTask id="gapPause" name="Responder gap (_inbox/&lt;slug&gt;-gap.md)" />
    <bpmn:task id="rebase" name="Rebase da base + resolver conflitos" />
    <bpmn:exclusiveGateway id="gConflict" name="conflito não-trivial?" />
    <bpmn:endEvent id="callYuri" name="PARAR — chamar o Yuri" />
    <bpmn:task id="bump" name="Bump versão FE+BE + commit chore(release)" />
    <bpmn:task id="pr" name="Abrir PR (gh pr create)" />
    <bpmn:endEvent id="endev" name="PR aberto" />

    <bpmn:userTask id="interview" name="Entrevista profunda — 4 eixos (Entity/Action/Invariant/Integration)" />
    <bpmn:task id="ontology" name="Propõe diff em ontology/ (Dev aprova)" />
    <bpmn:task id="taskscoper" name="Gera tasks.md + acceptance criteria" />
    <bpmn:task id="autoloop" name="TDD → impl → typecheck → lint → test → PatternGuardian" />
    <bpmn:exclusiveGateway id="infogap" name="InfoGapBroker: pergunta P0?" />
    <bpmn:exclusiveGateway id="gGreen" name="verde?" />
    <bpmn:task id="p0loop" name="Sub-loop P0 (NÃO dispara novo Regis-Review)" />
    <bpmn:task id="regis" name="/regis-review → KANBAN.md" />
    <bpmn:task id="triage" name="Triar P0 / P1·P2·P3 (P1-3 → inbox)" />
    <bpmn:exclusiveGateway id="gP0" name="P0 crítico?" />

    <bpmn:sequenceFlow id="f1" sourceRef="start" targetRef="wt" />
    <bpmn:sequenceFlow id="f2" sourceRef="wt" targetRef="interview" />
    <bpmn:sequenceFlow id="f3" sourceRef="interview" targetRef="reviewFlag" />
    <bpmn:sequenceFlow id="f4" sourceRef="reviewFlag" targetRef="gEntity" />
    <bpmn:sequenceFlow id="f5" name="sim" sourceRef="gEntity" targetRef="ontology" />
    <bpmn:sequenceFlow id="f6" name="não" sourceRef="gEntity" targetRef="taskscoper" />
    <bpmn:sequenceFlow id="f7" sourceRef="ontology" targetRef="taskscoper" />
    <bpmn:sequenceFlow id="f8" sourceRef="taskscoper" targetRef="confirmTasks" />
    <bpmn:sequenceFlow id="f9" sourceRef="confirmTasks" targetRef="autoloop" />
    <bpmn:sequenceFlow id="f10" sourceRef="autoloop" targetRef="infogap" />
    <bpmn:sequenceFlow id="f11" name="sim" sourceRef="infogap" targetRef="gapPause" />
    <bpmn:sequenceFlow id="f12" name="resume" sourceRef="gapPause" targetRef="autoloop" />
    <bpmn:sequenceFlow id="f13" name="não" sourceRef="infogap" targetRef="gGreen" />
    <bpmn:sequenceFlow id="f14" name="não (reitera)" sourceRef="gGreen" targetRef="autoloop" />
    <bpmn:sequenceFlow id="f15" name="sim" sourceRef="gGreen" targetRef="regis" />
    <bpmn:sequenceFlow id="f16" sourceRef="regis" targetRef="triage" />
    <bpmn:sequenceFlow id="f17" sourceRef="triage" targetRef="gP0" />
    <bpmn:sequenceFlow id="f18" name="sim" sourceRef="gP0" targetRef="p0loop" />
    <bpmn:sequenceFlow id="f19" name="re-check" sourceRef="p0loop" targetRef="gP0" />
    <bpmn:sequenceFlow id="f20" name="não" sourceRef="gP0" targetRef="rebase" />
    <bpmn:sequenceFlow id="f21" sourceRef="rebase" targetRef="gConflict" />
    <bpmn:sequenceFlow id="f22" name="sim" sourceRef="gConflict" targetRef="callYuri" />
    <bpmn:sequenceFlow id="f23" name="não" sourceRef="gConflict" targetRef="bump" />
    <bpmn:sequenceFlow id="f24" sourceRef="bump" targetRef="pr" />
    <bpmn:sequenceFlow id="f25" sourceRef="pr" targetRef="endev" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="di">
    <bpmndi:BPMNPlane id="plane" bpmnElement="Collab_feature_new">
      <bpmndi:BPMNShape id="Pool_di" bpmnElement="Pool" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="3760" height="840" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Dev_di" bpmnElement="Lane_Dev" isHorizontal="true">
        <dc:Bounds x="190" y="80" width="3730" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Office_di" bpmnElement="Lane_Office" isHorizontal="true">
        <dc:Bounds x="190" y="220" width="3730" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Onto_di" bpmnElement="Lane_Onto" isHorizontal="true">
        <dc:Bounds x="190" y="360" width="3730" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Task_di" bpmnElement="Lane_Task" isHorizontal="true">
        <dc:Bounds x="190" y="500" width="3730" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Auto_di" bpmnElement="Lane_Auto" isHorizontal="true">
        <dc:Bounds x="190" y="640" width="3730" height="140" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Regis_di" bpmnElement="Lane_Regis" isHorizontal="true">
        <dc:Bounds x="190" y="780" width="3730" height="140" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="start_di" bpmnElement="start"><dc:Bounds x="277" y="132" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="wt_di" bpmnElement="wt"><dc:Bounds x="410" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="reviewFlag_di" bpmnElement="reviewFlag"><dc:Bounds x="770" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gEntity_di" bpmnElement="gEntity" isMarkerVisible="true"><dc:Bounds x="995" y="130" width="40" height="40" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="confirmTasks_di" bpmnElement="confirmTasks"><dc:Bounds x="1490" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gapPause_di" bpmnElement="gapPause"><dc:Bounds x="1850" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="rebase_di" bpmnElement="rebase"><dc:Bounds x="2930" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gConflict_di" bpmnElement="gConflict" isMarkerVisible="true"><dc:Bounds x="3155" y="130" width="40" height="40" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="callYuri_di" bpmnElement="callYuri"><dc:Bounds x="3157" y="180" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="bump_di" bpmnElement="bump"><dc:Bounds x="3290" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="pr_di" bpmnElement="pr"><dc:Bounds x="3470" y="115" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="endev_di" bpmnElement="endev"><dc:Bounds x="3697" y="132" width="36" height="36" /></bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="interview_di" bpmnElement="interview"><dc:Bounds x="590" y="255" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ontology_di" bpmnElement="ontology"><dc:Bounds x="1130" y="395" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="taskscoper_di" bpmnElement="taskscoper"><dc:Bounds x="1310" y="535" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="autoloop_di" bpmnElement="autoloop"><dc:Bounds x="1670" y="675" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="infogap_di" bpmnElement="infogap" isMarkerVisible="true"><dc:Bounds x="1895" y="690" width="40" height="40" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gGreen_di" bpmnElement="gGreen" isMarkerVisible="true"><dc:Bounds x="2075" y="690" width="40" height="40" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="p0loop_di" bpmnElement="p0loop"><dc:Bounds x="2750" y="675" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="regis_di" bpmnElement="regis"><dc:Bounds x="2210" y="815" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="triage_di" bpmnElement="triage"><dc:Bounds x="2390" y="815" width="130" height="70" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="gP0_di" bpmnElement="gP0" isMarkerVisible="true"><dc:Bounds x="2615" y="830" width="40" height="40" /></bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="f1_di" bpmnElement="f1"><di:waypoint x="313" y="150" /><di:waypoint x="410" y="150" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f2_di" bpmnElement="f2"><di:waypoint x="540" y="150" /><di:waypoint x="655" y="150" /><di:waypoint x="655" y="255" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f3_di" bpmnElement="f3"><di:waypoint x="720" y="290" /><di:waypoint x="835" y="290" /><di:waypoint x="835" y="185" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f4_di" bpmnElement="f4"><di:waypoint x="900" y="150" /><di:waypoint x="995" y="150" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f5_di" bpmnElement="f5"><di:waypoint x="1015" y="170" /><di:waypoint x="1015" y="430" /><di:waypoint x="1130" y="430" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f6_di" bpmnElement="f6"><di:waypoint x="1035" y="150" /><di:waypoint x="1375" y="150" /><di:waypoint x="1375" y="535" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f7_di" bpmnElement="f7"><di:waypoint x="1195" y="465" /><di:waypoint x="1195" y="570" /><di:waypoint x="1310" y="570" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f8_di" bpmnElement="f8"><di:waypoint x="1440" y="570" /><di:waypoint x="1555" y="570" /><di:waypoint x="1555" y="185" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f9_di" bpmnElement="f9"><di:waypoint x="1555" y="185" /><di:waypoint x="1555" y="710" /><di:waypoint x="1670" y="710" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f10_di" bpmnElement="f10"><di:waypoint x="1800" y="710" /><di:waypoint x="1895" y="710" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f11_di" bpmnElement="f11"><di:waypoint x="1915" y="690" /><di:waypoint x="1915" y="185" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f12_di" bpmnElement="f12"><di:waypoint x="1850" y="150" /><di:waypoint x="1735" y="150" /><di:waypoint x="1735" y="675" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f13_di" bpmnElement="f13"><di:waypoint x="1935" y="710" /><di:waypoint x="2075" y="710" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f14_di" bpmnElement="f14"><di:waypoint x="2090" y="730" /><di:waypoint x="2090" y="770" /><di:waypoint x="1735" y="770" /><di:waypoint x="1735" y="745" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f15_di" bpmnElement="f15"><di:waypoint x="2100" y="730" /><di:waypoint x="2100" y="850" /><di:waypoint x="2210" y="850" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f16_di" bpmnElement="f16"><di:waypoint x="2340" y="850" /><di:waypoint x="2390" y="850" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f17_di" bpmnElement="f17"><di:waypoint x="2520" y="850" /><di:waypoint x="2615" y="850" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f18_di" bpmnElement="f18"><di:waypoint x="2635" y="830" /><di:waypoint x="2635" y="710" /><di:waypoint x="2750" y="710" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f19_di" bpmnElement="f19"><di:waypoint x="2815" y="745" /><di:waypoint x="2815" y="850" /><di:waypoint x="2655" y="850" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f20_di" bpmnElement="f20"><di:waypoint x="2635" y="870" /><di:waypoint x="2635" y="890" /><di:waypoint x="2995" y="890" /><di:waypoint x="2995" y="185" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f21_di" bpmnElement="f21"><di:waypoint x="3060" y="150" /><di:waypoint x="3155" y="150" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f22_di" bpmnElement="f22"><di:waypoint x="3175" y="170" /><di:waypoint x="3175" y="180" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f23_di" bpmnElement="f23"><di:waypoint x="3195" y="150" /><di:waypoint x="3290" y="150" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f24_di" bpmnElement="f24"><di:waypoint x="3420" y="150" /><di:waypoint x="3470" y="150" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="f25_di" bpmnElement="f25"><di:waypoint x="3600" y="150" /><di:waypoint x="3697" y="150" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
