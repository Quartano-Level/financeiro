# Backend API base URL (where the username/password login lives).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Authentication — simple username/password login against the backend
# (POST /auth/login). The token is stored in localStorage. No Supabase/OAuth.

# NEXT_PUBLIC_DEV_AUTH_BYPASS=true skips the auth gate so local development
# works without logging in. Default off — must NEVER be true in a deployed
# build.
# NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# NEXT_PUBLIC_ENV identifies the running environment. Dev-bypass is only
# permitted when this is "local" (the default for local dev). On any other
# value (prd/stg/hml/…) a build with NEXT_PUBLIC_DEV_AUTH_BYPASS=true crashes
# at startup via assertAuthEnv() instead of shipping unauthenticated
# (arch-review card security-1).
NEXT_PUBLIC_ENV=local
