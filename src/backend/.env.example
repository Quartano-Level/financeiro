# Conexos ERP
CONEXOS_BASE_URL=https://columbiatrading.conexos.cloud/api
CONEXOS_USERNAME=
CONEXOS_PASSWORD=

# Server
PORT=3002

# Database — Postgres connection string (Supabase Session pooler in prod).
databaseConnectionString=

# CORS — comma-separated whitelist of allowed origins.
# When unset, defaults to http://localhost:3000.
ALLOWED_ORIGINS=http://localhost:3000

# Authentication — simple username/password login (the app signs its own JWT).
#
# AUTH_JWT_SECRET — HS256 secret used to SIGN and VERIFY the app's own login
# tokens. Generate a strong random value (e.g. `openssl rand -base64 48`).
# Required unless DEV_AUTH_BYPASS=true.
AUTH_JWT_SECRET=
#
# Admin seed (used by `npm run seed:admin`). UPSERTs this user into `app_user`
# with a bcrypt-hashed password. Set a strong ADMIN_PASSWORD for production.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
#
# --- Legacy Supabase auth (optional, NOT used by the simple login) -----------
# SUPABASE_URL — Supabase project URL (ES256/JWKS). Leave blank.
SUPABASE_URL=
# SUPABASE_JWT_SECRET — legacy HS256 fallback, used only if AUTH_JWT_SECRET is
# unset. Leave blank when using AUTH_JWT_SECRET.
SUPABASE_JWT_SECRET=
#
# AUTH_JWT_SECRET (or SUPABASE_URL/SUPABASE_JWT_SECRET) is required unless DEV_AUTH_BYPASS=true.
# DEV_AUTH_BYPASS=true skips JWT validation for local development. Default off.
# Must NEVER be true in a deployed environment. When DEV_AUTH_BYPASS=true is
# combined with environment=prd/stg/hml, loadAuthEnv() throws at startup so the
# API never boots unauthenticated (arch-review card security-1).
# DEV_AUTH_BYPASS=false

# environment — running environment (local/dev/hml/stg/prd). Defaults to local.
# Deployed environments (prd/stg/hml) reject DEV_AUTH_BYPASS=true at startup.
# environment=local

# Debug (1 = verbose)
# DEBUG_VERBOSE=1

# Conexos — Configuracoes operacionais
# CONEXOS_FIL_COD=2
# usnCod is captured from the /login response (resp.data.usnCod) — no env override.

# Fase 3 (ADR-0013) — guard-rails da ESCRITA no fin010 (baixa/permuta). SEGUROS
# por padrao: escrita DESLIGADA e dry-run LIGADO (so monta/loga o payload, sem POST).
# Escrita real exige AS DUAS: WRITE_ENABLED=true E DRY_RUN=false. Homologacao-first:
# aponte CONEXOS_BASE_URL p/ https://columbiatrading-hml.conexos.cloud/api antes.
# Runbook: docs/runbooks/fin010-write-cutover.md
# CONEXOS_WRITE_ENABLED=false
# CONEXOS_DRY_RUN=true
