# Conexos ERP
CONEXOS_BASE_URL=https://columbiatrading.conexos.cloud/api
CONEXOS_USERNAME=
CONEXOS_PASSWORD=

# Server
PORT=3002

# CORS — comma-separated whitelist of allowed origins.
# When unset, defaults to http://localhost:3000.
ALLOWED_ORIGINS=http://localhost:3000

# Authentication — Supabase JWT validation (arch-review security-1 / security-7).
#
# SUPABASE_URL (PREFERRED) — your Supabase project URL, e.g.
# https://<ref>.supabase.co. When set, user access tokens are verified
# asymmetrically (ES256) against the project's JWKS at
# ${SUPABASE_URL}/auth/v1/.well-known/jwks.json, with issuer
# ${SUPABASE_URL}/auth/v1 and audience "authenticated". Modern Supabase
# projects sign user login tokens with ES256, so this is the correct path.
SUPABASE_URL=
#
# SUPABASE_JWT_SECRET (LEGACY FALLBACK) — the HS256 signing secret from your
# Supabase project (Settings → API → JWT Settings). Only used when SUPABASE_URL
# is NOT set, for projects still on symmetric (HS256) signing.
SUPABASE_JWT_SECRET=
#
# Either SUPABASE_URL or SUPABASE_JWT_SECRET is required unless DEV_AUTH_BYPASS=true.
# DEV_AUTH_BYPASS=true skips JWT validation for local development. Default off.
# Must NEVER be true in a deployed environment. When DEV_AUTH_BYPASS=true is
# combined with environment=prd/stg/hml, loadAuthEnv() throws at startup so the
# API never boots unauthenticated (arch-review card security-1).
# DEV_AUTH_BYPASS=false

# environment — running environment (local/dev/hml/stg/prd). Defaults to local.
# Deployed environments (prd/stg/hml) reject DEV_AUTH_BYPASS=true at startup.
# environment=local

# Debug (1 = verbose)
# DEBUG_VERBOSE=1

# Conexos — Configuracoes operacionais
# CONEXOS_FIL_COD=2
# usnCod is captured from the /login response (resp.data.usnCod) — no env override.
